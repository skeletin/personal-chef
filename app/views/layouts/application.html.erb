<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Personal chef — Bookings" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#fffbeb">
    <meta name="description" content="Book a personal chef for private dinners and meal prep.">
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "tailwind", media: "all" %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700&family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&display=swap" rel="stylesheet">
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E👨🏾‍🍳%3C/text%3E%3C/svg%3E">
  </head>

  <body class="bg-[radial-gradient(ellipse_120%_80%_at_50%_-20%,oklch(0.97_0.04_85),transparent)] bg-zinc-50 min-h-screen">
    <%= render "layouts/flash" %>
    <%= yield %>
  </body>
</html>
