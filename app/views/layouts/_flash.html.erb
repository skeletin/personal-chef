<% if notice.present? %>
  <div class="relative z-20 px-6 pt-6 sm:px-8" role="status" aria-live="polite">
    <div class="mx-auto flex max-w-lg animate-rise items-start gap-3 rounded-2xl border border-emerald-200/90 bg-emerald-50/95 px-4 py-3.5 text-emerald-950 shadow-lg shadow-emerald-900/10 ring-1 ring-emerald-100 backdrop-blur-sm">
      <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white shadow-inner">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </span>
      <div class="min-w-0 flex-1 pt-0.5 text-sm font-medium leading-snug"><%= notice %></div>
    </div>
  </div>
<% end %>

<% if alert.present? %>
  <div class="relative z-20 px-6 pt-6 sm:px-8" role="alert" aria-live="assertive">
    <div class="mx-auto flex max-w-lg animate-rise items-start gap-3 rounded-2xl border border-red-200/90 bg-red-50/95 px-4 py-3.5 text-red-950 shadow-lg shadow-red-900/10 ring-1 ring-red-100 backdrop-blur-sm">
      <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-red-500 text-white shadow-inner">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.3 3.6L2.6 17A2 2 0 004.4 20h15.2a2 2 0 001.8-3l-7.7-13.4a2 2 0 00-3.6 0z" />
        </svg>
      </span>
      <div class="min-w-0 flex-1 pt-0.5 text-sm font-medium leading-snug"><%= alert %></div>
    </div>
  </div>
<% end %>
