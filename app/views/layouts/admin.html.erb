<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Admin — Liquor inventory" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#f8fafc">
    <meta name="robots" content="noindex, nofollow">
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "tailwind", media: "all" %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@300;400;500;600;700&family=Rubik:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
  </head>

  <body class="min-h-screen bg-brand-bg">
    <%= render "layouts/admin_flash" %>
    <%= render "layouts/admin_header" %>
    <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8 lg:pb-14">
      <%= yield %>
    </main>
  </body>
</html>
