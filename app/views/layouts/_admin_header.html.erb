<header class="border-b border-slate-200/90 bg-brand-surface/90 backdrop-blur-sm">
  <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8">
    <%= link_to admin_liquors_path, class: "font-display text-lg font-semibold tracking-tight text-brand-primary hover:text-sky-800 transition-colors duration-200" do %>
      Inventory admin
    <% end %>
    <nav class="flex flex-wrap items-center gap-3 text-sm">
      <%= link_to "View storefront", root_path,
          class: "cursor-pointer font-medium text-brand-muted underline decoration-sky-700/35 decoration-2 underline-offset-4 transition-colors duration-200 hover:text-sky-900" %>
      <%= button_to "Sign out", session_path,
          method: :delete,
          class: "cursor-pointer rounded-xl border border-slate-300 bg-brand-surface px-3 py-1.5 font-semibold text-slate-700 shadow-sm transition-colors duration-200 hover:border-slate-400 hover:bg-slate-50" %>
    </nav>
  </div>
</header>
