<%= content_for :head do %>
  <%= tag.script src: "/liquor_photo_lightbox.js", defer: true %>
<% end %>
<%= content_for :title, "Liquor inventory — current stock & prices" %>

<%= render "application/inventory_nav" %>

<div class="animate-rise mx-auto max-w-5xl px-4 pb-24 pt-8 sm:px-6 lg:px-8 lg:pb-28">
  <header class="text-balance pb-12 text-center sm:pb-16">
    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-cta">
      Spirits & selection
    </p>
    <h1 class="font-display mt-4 text-pretty text-3xl font-semibold tracking-tight text-brand-primary sm:text-4xl">
      What&apos;s available <span class="text-brand-cta">right now.</span>
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-pretty text-base leading-relaxed text-brand-muted">
      Live counts, photos, and shelf prices update when stock changes.
    </p>
    <p class="mx-auto mt-5 max-w-2xl text-pretty text-sm leading-relaxed text-brand-muted sm:text-[0.9375rem]">
      <span class="font-semibold text-slate-700">About these prices.</span>
      Each number reflects the bottle&apos;s <strong class="font-black tracking-tight text-slate-950">quality</strong> and how it stacks up against
      <span class="font-medium text-brand-primary">typical liquor-store shelf prices</span>
      — benchmarks I add beside your price so you can eyeball the deal. Those comps are snapshots I curate myself, not scraped live pricing from every shop.
    </p>
  </header>

  <section aria-labelledby="how-it-works-heading" class="animate-rise-delay-1 animate-rise mx-auto mb-12 max-w-2xl rounded-2xl border border-sky-900/12 bg-brand-surface p-6 shadow-md shadow-slate-900/[0.04] ring-1 ring-sky-700/15 sm:p-8">
    <h2 id="how-it-works-heading" class="font-display text-center text-lg font-semibold tracking-tight text-brand-primary sm:text-xl">
      How it works
    </h2>
    <ol class="mt-6 list-none space-y-5 text-sm leading-relaxed text-brand-muted sm:text-base [&>li]:flex [&>li]:gap-4">
      <li>
        <span class="mt-0.5 inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-sky-100 text-sm font-semibold text-sky-900 ring-1 ring-sky-200/80">
          1
        </span>
        <span>
          <span class="font-medium text-brand-primary">Text me what you want</span>
          —
          Tell me which bottle(s) and quantity from what you see listed here (you can tap a photo to enlarge it).
        </span>
      </li>
      <li>
        <span class="mt-0.5 inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-sky-100 text-sm font-semibold text-sky-900 ring-1 ring-sky-200/80">
          2
        </span>
        <span>
          <span class="font-medium text-brand-primary">Pay</span>
          —
          Once you&apos;ve sent the money, those bottles are yours. I&apos;ll confirm with you via text like usual.
        </span>
      </li>
      <li>
        <span class="mt-0.5 inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-sky-100 text-sm font-semibold text-sky-900 ring-1 ring-sky-200/80">
          3
        </span>
        <span>
          <span class="font-medium text-brand-primary">Fresh counts on this page</span>
          —
          I update the inventory here after each sale so the list stays accurate for the next shopper.
        </span>
      </li>
    </ol>
    <p class="mt-6 border-t border-slate-200/80 pt-6 text-center text-sm leading-relaxed text-brand-muted sm:text-[0.9375rem]">
      <span class="font-semibold text-brand-primary">First come, first served.</span>
      Counts aren&apos;t held on a text alone — whoever pays while it&apos;s still listed gets it.
    </p>
  </section>

  <% if @liquors.empty? %>
    <section class="mx-auto max-w-md rounded-[1.75rem] border border-slate-200/90 bg-brand-surface p-10 text-center shadow-lg shadow-slate-900/[0.04] ring-1 ring-slate-100">
      <p class="font-display text-xl font-semibold text-brand-primary">Checking the shelves…</p>
      <p class="mt-2 text-sm leading-relaxed text-brand-muted">
        Nothing listed yet — check back shortly.
      </p>
    </section>
  <% else %>
    <%# Desktop / tablet %>
    <div class="animate-rise animate-rise-delay-1 hidden overflow-x-auto rounded-2xl border border-slate-200/95 bg-brand-surface shadow-xl shadow-slate-900/[0.04] ring-1 ring-slate-100 md:block">
      <table class="min-w-full text-left text-sm">
        <caption class="sr-only">Liquor inventory, photos, benchmark pricing, stock quantity, and your price.</caption>
        <thead class="sticky top-0 border-b border-slate-200/90 bg-slate-50/95 text-xs font-semibold uppercase tracking-wider text-brand-muted backdrop-blur-sm">
          <tr>
            <th scope="col" class="px-3 py-4 pl-5 text-brand-primary lg:pl-8">Photo</th>
            <th scope="col" class="px-3 py-4 text-brand-primary">Item</th>
            <th scope="col" class="px-3 py-4 text-brand-primary">Category</th>
            <th scope="col" class="px-3 py-4 text-brand-primary lg:whitespace-nowrap">In stock</th>
            <th scope="col" class="px-5 py-4 pr-5 text-brand-primary lg:min-w-[10rem] lg:px-8 lg:text-right lg:align-top">
              Price & compare
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @liquors.each_with_index do |liquor, i| %>
            <tr class="<%= 'bg-white' if i.even? %> <%= 'bg-slate-50/40' unless i.even? %> hover:bg-sky-50/40 transition-colors duration-200">
              <td class="align-middle whitespace-nowrap px-3 py-2 pl-5 min-w-0 lg:w-20 lg:pl-8">
                <%= render "liquor_photo_thumb", liquor:, layout: :table, expandable: true %>
              </td>
              <th scope="row" class="cursor-default px-3 py-4 font-semibold text-brand-primary">
                <%= liquor.name %>
              </th>
              <td class="px-3 py-4 text-brand-muted">
                <%= liquor.category.presence || "—" %>
              </td>
              <td class="px-3 py-4">
                <% if liquor.quantity.to_i > 0 %>
                  <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-900 ring-1 ring-emerald-200/70">
                    <%= pluralize(liquor.quantity.to_i, "bottle") %>
                  </span>
                <% else %>
                  <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-950 ring-1 ring-amber-200/80">
                    Out of stock
                  </span>
                <% end %>
              </td>
              <td class="px-5 py-4 pr-5 align-top text-brand-primary lg:px-8">
                <div class="flex flex-col gap-0 lg:items-end lg:text-right">
                  <span class="font-semibold tabular-nums"><%= number_to_currency liquor.price %></span>
                  <%= render "liquor_public_price_compare", liquor:, layout: :table %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Mobile %>
    <ul class="animate-rise animate-rise-delay-1 space-y-4 md:hidden" role="list">
      <% @liquors.each do |liquor| %>
        <li class="flex min-h-0 flex-col overflow-hidden rounded-2xl border border-slate-200/95 bg-brand-surface shadow-md shadow-slate-900/[0.04] ring-1 ring-slate-100">
          <%= render "liquor_photo_thumb", liquor:, layout: :card, expandable: true %>
          <div class="flex flex-wrap items-start justify-between gap-2 p-5 pt-4">
            <div>
              <p class="font-display text-lg font-semibold tracking-tight text-brand-primary"><%= liquor.name %></p>
              <% if liquor.category.present? %>
                <p class="mt-1 text-xs uppercase tracking-wide text-brand-muted"><%= liquor.category %></p>
              <% end %>
            </div>
            <p class="w-full shrink-0 text-right font-semibold tabular-nums text-brand-primary sm:w-auto"><%= number_to_currency liquor.price %></p>
          </div>
          <%= render "liquor_public_price_compare", liquor:, layout: :card %>
          <div class="border-t border-slate-100 px-5 pb-5 pt-0">
            <% if liquor.quantity.to_i > 0 %>
              <span class="mt-4 inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-900 ring-1 ring-emerald-200/70">
                <%= pluralize(liquor.quantity.to_i, "bottle") %>
              </span>
            <% else %>
              <span class="mt-4 inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-950 ring-1 ring-amber-200/80">
                Out of stock
              </span>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>

    <%= render "liquor_photo_lightbox" %>
  <% end %>

  <footer class="mt-20 border-t border-slate-200/70 pt-10 text-center">
    <p class="text-xs text-brand-muted">© <%= Time.current.year %></p>
  </footer>
</div>
