<%# locals: liquor (Liquor), layout: :table (default) or :card, expandable: false %>

<% expandable = !!local_assigns.fetch(:expandable, false) %>
<% variant = local_assigns.fetch(:layout, :table).to_sym %>
<% placeholder_label = "No bottle photo for #{liquor.name}" %>
<% blob_src = (liquor.photo.attached? ? url_for(liquor.photo) : nil) %>
<% enlarge_aria = { label: "View full-size #{liquor.name} photo", haspopup: "dialog", controls: "liquor-photo-lightbox" } %>

<% thumb_classes_card = [
     "relative h-[4.5rem] max-h-[4.5rem] w-full shrink-0 overflow-hidden bg-slate-100 min-h-0",
     "ring-1 ring-inset ring-slate-100/80 sm:h-20 sm:max-h-20 md:h-24 md:max-h-24"
   ].join(" ") %>
<% thumb_classes_inline = [
     "relative size-12 max-h-12 max-w-12 shrink-0 overflow-hidden rounded-md bg-slate-100 min-h-0 min-w-0",
     "ring-1 ring-slate-200 sm:size-14 sm:max-h-14 sm:max-w-14"
   ].join(" ") %>
<% img_src = blob_src %>
<% img_inner = lambda do %>
  <%= tag.img(
        src: img_src,
        class: "pointer-events-none absolute inset-0 z-0 h-full w-full object-cover object-center transition-opacity duration-200",
        alt: "Photo of #{liquor.name} bottle.",
        decoding: "async",
        loading: "lazy"
      ) %>
<% end %>
<% expandable_btn_styles = [
     "appearance-none outline-none shadow-none bg-slate-100 text-left cursor-pointer touch-manipulation",
     "transition-[filter] duration-150 hover:brightness-[0.98] active:brightness-[0.94]",
     "focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white"
   ].join(" ") %>

<% if blob_src.present? && variant == :card %>
  <% if expandable %>
    <%= tag.button(
          type: "button",
          class: "#{thumb_classes_card} #{expandable_btn_styles}",
          aria: enlarge_aria,
          data: { photo_lightbox_src: blob_src, photo_lightbox_name: liquor.name }
        ) do %>
      <% img_inner.call %>
    <% end %>
  <% else %>
    <div class="<%= thumb_classes_card %>" role="presentation"><% img_inner.call %></div>
  <% end %>
<% elsif blob_src.present? %>
  <% if expandable %>
    <%= tag.button(
          type: "button",
          class: "#{thumb_classes_inline} #{expandable_btn_styles}",
          aria: enlarge_aria,
          data: { photo_lightbox_src: blob_src, photo_lightbox_name: liquor.name }
        ) do %>
      <% img_inner.call %>
    <% end %>
  <% else %>
    <div class="<%= thumb_classes_inline %>" role="presentation"><% img_inner.call %></div>
  <% end %>
<% elsif variant == :card %>
  <div class="flex h-[4.5rem] max-h-[4.5rem] w-full shrink-0 items-center justify-center overflow-hidden bg-gradient-to-br from-slate-100 to-slate-50 ring-1 ring-inset ring-slate-100/80 sm:h-20 sm:max-h-20 md:h-24 md:max-h-24" role="img" aria-label="<%= placeholder_label %>">
    <svg class="size-9 text-slate-300 md:size-10" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3A1.5 1.5 0 0 0 1.5 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
    </svg>
  </div>
<% else %>
  <div class="relative flex size-12 max-h-12 max-w-12 shrink-0 items-center justify-center overflow-hidden rounded-md bg-gradient-to-br from-slate-100 to-slate-50 ring-1 ring-slate-200 sm:size-14 sm:max-h-14 sm:max-w-14" role="img" aria-label="<%= placeholder_label %>">
    <svg class="size-6 text-slate-300 sm:size-7" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3A1.5 1.5 0 0 0 1.5 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
    </svg>
  </div>
<% end %>
