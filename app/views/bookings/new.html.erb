<%= content_for :title, "Personal chef — Bookings" %>
<div class="font-sans text-zinc-900 min-h-screen">
  <header class="animate-rise mx-auto flex max-w-lg items-center justify-between px-6 pt-10 pb-2 sm:px-8">
    <span class="text-xs font-semibold uppercase tracking-[0.22em] text-amber-700/80">Personal chef</span>
    <a href="#book" class="text-sm font-medium text-zinc-800 underline decoration-amber-400/50 decoration-2 underline-offset-4 transition hover:text-amber-900 hover:decoration-amber-500">Book</a>
  </header>

  <main class="mx-auto max-w-lg px-6 pb-24 sm:px-8">
    <section class="animate-rise animate-rise-delay-1 flex flex-col items-center pt-8 text-center sm:pt-12">
      <figure class="relative mx-auto w-full max-w-[280px] sm:max-w-[320px]">
        <div class="hero-float hero-ring-pulse overflow-hidden rounded-[2rem] bg-gradient-to-br from-amber-100 to-zinc-100 p-[3px] ring-1 ring-amber-200/60 shadow-xl shadow-amber-950/10">
          <div class="overflow-hidden rounded-[1.85rem] bg-zinc-100 ring-1 ring-white/80">
            <%= image_tag "/me.PNG", alt: "Portrait of the chef", class: "aspect-[3/4] w-full object-cover transition duration-500 hover:scale-[1.02]", loading: "eager" %>
          </div>
        </div>
      </figure>

      <h1 class="font-display mt-10 text-balance text-3xl font-semibold tracking-tight text-zinc-950 sm:text-[2.15rem] sm:leading-[1.15]">
        Private dinners, home cooking, <span class="text-amber-900">your table.</span>
      </h1>
      <p class="mt-4 max-w-sm text-pretty text-base leading-relaxed text-zinc-600">
        Book me to cook for you — date nights, small gatherings, or regular meal prep.
      </p>

      <a
        href="#book"
        class="animate-rise animate-rise-delay-2 mt-10 inline-flex items-center justify-center rounded-full bg-zinc-950 px-8 py-3.5 text-sm font-semibold text-white shadow-lg shadow-zinc-900/25 transition hover:scale-[1.03] hover:bg-zinc-800 active:scale-[0.98]"
      >
        Request a date
      </a>
    </section>

    <section class="animate-rise animate-rise-delay-3 mt-20 border-t border-amber-200/40 pt-16">
      <h2 class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-amber-800/80">What I offer</h2>
      <ul class="mt-10 space-y-6 text-center text-sm leading-relaxed text-zinc-600">
        <li class="rounded-2xl border border-transparent px-3 py-1 transition hover:border-amber-100 hover:bg-white/60">
          <span class="block font-semibold text-zinc-900">Dinner for two or a few</span>
          <span class="mt-1 block text-zinc-500">Course menus tailored to you.</span>
        </li>
        <li class="rounded-2xl border border-transparent px-3 py-1 transition hover:border-amber-100 hover:bg-white/60">
          <span class="block font-semibold text-zinc-900">Small parties</span>
          <span class="mt-1 block text-zinc-500">Family-style or plated — we’ll align on the vibe.</span>
        </li>
        <li class="rounded-2xl border border-transparent px-3 py-1 transition hover:border-amber-100 hover:bg-white/60">
          <span class="block font-semibold text-zinc-900">Meal prep blocks</span>
          <span class="mt-1 block text-zinc-500">Batch cooking for the week, your kitchen.</span>
        </li>
      </ul>
    </section>

    <section id="book" class="animate-rise animate-rise-delay-4 mt-20 scroll-mt-8 border-t border-amber-200/40 pt-16">
      <h2 class="font-display text-center text-2xl font-semibold tracking-tight text-zinc-950">Book</h2>
      <p class="mx-auto mt-3 max-w-sm text-center text-sm text-zinc-600">
        Send a booking request below. I’ll get the details and reply with availability.
      </p>

      <% if @booking.errors.any? %>
        <div
          class="animate-fade-in mx-auto mt-8 max-w-md overflow-hidden rounded-2xl border border-red-200 bg-red-50/90 text-left text-red-950 shadow-md shadow-red-900/5 ring-1 ring-red-100"
          role="alert"
          aria-live="assertive"
        >
          <div class="flex gap-3 border-b border-red-100/80 bg-red-100/50 px-4 py-3">
            <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-red-500 text-white">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
            <div class="min-w-0 pt-0.5">
              <p class="text-sm font-semibold">Couldn’t send yet</p>
              <p class="text-xs text-red-800/90">Fix the following and try again.</p>
            </div>
          </div>
          <ul class="list-inside list-disc space-y-1.5 px-4 py-3 text-sm text-red-900 marker:text-red-400">
            <% @booking.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @booking, class: "mt-10 space-y-5", id: "booking-form" do |f| %>
        <label class="group block text-left">
          <span class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Name</span>
          <%= f.text_field :name, autocomplete: "name", required: true,
              aria: { invalid: @booking.errors[:name].any? },
              class: "w-full rounded-xl border bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm transition placeholder:text-zinc-400 focus:border-amber-500/70 focus:outline-none focus:ring-2 focus:ring-amber-400/30 #{ @booking.errors[:name].any? ? 'border-red-400 ring-1 ring-red-200' : 'border-zinc-200 hover:border-zinc-300' }" %>
          <% if @booking.errors[:name].any? %>
            <span class="mt-1 block text-xs font-medium text-red-600"><%= @booking.errors[:name].first %></span>
          <% end %>
        </label>
        <label class="block text-left">
          <span class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Guests</span>
          <%= f.text_field :guests, inputmode: "numeric",
              class: "w-full rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm transition placeholder:text-zinc-400 hover:border-zinc-300 focus:border-amber-500/70 focus:outline-none focus:ring-2 focus:ring-amber-400/30" %>
        </label>
        <label class="block text-left">
          <span class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Preferred dates</span>
          <%= f.text_field :preferred_dates,
              class: "w-full rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm transition placeholder:text-zinc-400 hover:border-zinc-300 focus:border-amber-500/70 focus:outline-none focus:ring-2 focus:ring-amber-400/30" %>
        </label>
        <label class="block text-left">
          <span class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Location</span>
          <%= f.text_field :location, autocomplete: "address-level2",
              class: "w-full rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm transition placeholder:text-zinc-400 hover:border-zinc-300 focus:border-amber-500/70 focus:outline-none focus:ring-2 focus:ring-amber-400/30" %>
        </label>
        <label class="block text-left">
          <span class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Notes</span>
          <%= f.text_area :notes, rows: 4, placeholder: "Diet, occasion, anything I should know",
              class: "w-full resize-y rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm text-zinc-900 shadow-sm transition placeholder:text-zinc-400 hover:border-zinc-300 focus:border-amber-500/70 focus:outline-none focus:ring-2 focus:ring-amber-400/30" %>
        </label>

        <div class="mt-10">
          <%= f.submit "Send request",
              class: "w-full cursor-pointer rounded-full bg-gradient-to-r from-zinc-900 to-zinc-800 py-3.5 text-center text-sm font-semibold text-amber-50 shadow-lg shadow-zinc-900/30 transition hover:scale-[1.02] hover:from-zinc-800 hover:to-zinc-700 active:scale-[0.98] border-0" %>
        </div>
      <% end %>
    </section>
  </main>

  <footer class="border-t border-amber-200/40 py-10 text-center">
    <p class="text-xs text-zinc-500">© <%= Time.current.year %></p>
  </footer>
</div>
